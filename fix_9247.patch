+        # Progressive alignment: per-group block sizes sorted descending.
+        # During find_longest_cache_hit(), we try the largest alignment first
+        # and back off to smaller ones when groups disagree, finding the
+        # largest hit length where ALL groups match — without the coarse
+        # global LCM truncation that causes #9247.
+        self._progressive_align_steps = sorted(
+            {self._get_effective_block_size(spec) for spec, _, _ in self.attention_groups},
+            reverse=True,
+        )
+
+    def _try_align_all_groups(self, candidate_length: int, manager_results: list) -> int | None:
+        """Check if all groups accept candidate_length aligned to their block size.
+        Returns the aligned length if all pass, None if any group rejects."""
+        for idx, (spec, group_ids, _) in enumerate(self.attention_groups):
+            bsize = self._get_effective_block_size(spec)
+            aligned = (candidate_length // bsize) * bsize
+            blocks = manager_results[group_ids[0]]
+            if blocks is None or len(blocks) * bsize < aligned:
+                return None
+        return candidate_length
