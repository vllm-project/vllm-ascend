

FROM swr.cn-southwest-2.myhuaweicloud.com/base_image/ascend-ci/cann:9.0.0-910b-openeuler24.03-py3.12

ARG APT_CACHE_HOST=""
ARG UV_INDEX_URL="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple"
ARG UV_EXTRA_INDEX_URL="https://download.pytorch.org/whl/cpu/ https://mirrors.huaweicloud.com/ascend/repos/pypi"

# uv + pip environment (matches _selected_tests.yaml container env)
ENV UV_INDEX_URL=${UV_INDEX_URL} \
    UV_EXTRA_INDEX_URL="${UV_EXTRA_INDEX_URL}" \
    UV_INDEX_STRATEGY=unsafe-best-match \
    UV_INSECURE_HOST=cache-service.nginx-pypi-cache.svc.cluster.local \
    UV_HTTP_TIMEOUT=120 \
    UV_NO_CACHE=1 \
    UV_SYSTEM_PYTHON=1 \
    PIP_INDEX_URL=${UV_INDEX_URL} \
    PIP_TRUSTED_HOST=cache-service.nginx-pypi-cache.svc.cluster.local

RUN echo "hello world"

CMD ["/bin/bash"]
